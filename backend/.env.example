# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://inventario:inventario_dev@localhost:5432/inventario

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRATION=3600

# DIAN Integration (Facturación Electrónica)
# Options: 'direct' (SOAP) or 'provider' (REST intermediary like Alegra)
DIAN_INTEGRATION_MODE=provider
DIAN_PROVIDER_API_URL=
DIAN_PROVIDER_API_KEY=
# For direct SOAP integration:
DIAN_WSDL_URL=
DIAN_CERTIFICATE_PATH=
DIAN_CERTIFICATE_PASSWORD=

# Anthropic (Claude API for voice transaction parsing)
ANTHROPIC_API_KEY=sk-ant-api03-...

# AWS
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Sentry (Error Tracking)
SENTRY_DSN=

# Feature Flags (PostHog/Flagsmith)
FEATURE_FLAG_PROVIDER=posthog
FEATURE_FLAG_API_KEY=
FEATURE_FLAG_HOST=
