<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Inventario"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A73E8" />

        <TextView
            android:id="@+id/txt_last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textSize="11sp"
            android:textColor="#888888" />
    </LinearLayout>

    <!-- Metrics row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <!-- Ventas hoy -->
        <LinearLayout
            android:id="@+id/btn_sales"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg"
            android:padding="6dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/txt_today_revenue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B1B1F"
                android:maxLines="1" />

            <TextView
                android:id="@+id/txt_today_sales_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ventas"
                android:textSize="11sp"
                android:textColor="#666666" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ventas hoy"
                android:textSize="10sp"
                android:textColor="#999999"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Productos -->
        <LinearLayout
            android:id="@+id/btn_products"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg"
            android:padding="6dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/txt_total_products"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B1B1F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Productos"
                android:textSize="11sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Stock bajo -->
        <LinearLayout
            android:id="@+id/btn_inventory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_card_bg"
            android:padding="6dp"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/txt_low_stock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FBAC44" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock bajo"
                android:textSize="11sp"
                android:textColor="#666666" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_new_sale"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Nueva venta"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/widget_button_primary"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btn_ai"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Asistente IA"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:background="@drawable/widget_button_secondary"
            android:layout_marginStart="4dp" />
    </LinearLayout>
</LinearLayout>
